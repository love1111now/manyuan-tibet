@import "tailwindcss";
@import "tw-animate-css";

@custom-variant dark (&:is(.dark *));

/*
  溫暖柔和禪風 — Warm Zen Paper
  - 米白紙感底色、淡茶棕文字、鼠尾草綠與柔金作點綴
  - 字體：Kaisei Tokumin（Display）+ Noto Serif TC（Body）
  - 原則：留白、低對比的柔和層次、可長讀的呼吸感
*/

@theme inline {
  --radius: 1.25rem;
  --radius-sm: calc(var(--radius) - 8px);
  --radius-md: calc(var(--radius) - 4px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 8px);

  --font-display: "Kaisei Tokumin", ui-serif, Georgia, "Times New Roman", serif;
  --font-body: "Noto Serif TC", ui-serif, Georgia, "Times New Roman", serif;

  /* semantic tokens consumed by shadcn/ui */
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);
  --color-chart-1: var(--chart-1);
  --color-chart-2: var(--chart-2);
  --color-chart-3: var(--chart-3);
  --color-chart-4: var(--chart-4);
  --color-chart-5: var(--chart-5);
  --color-sidebar: var(--sidebar);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-ring: var(--sidebar-ring);
}

:root {
  /* Warm Zen Paper palette */
  --background: oklch(0.975 0.014 88);
  --foreground: oklch(0.235 0.028 55);

  --card: oklch(0.988 0.01 88);
  --card-foreground: oklch(0.235 0.028 55);

  --popover: oklch(0.988 0.01 88);
  --popover-foreground: oklch(0.235 0.028 55);

  /* soft ochre */
  --primary: oklch(0.66 0.11 75);
  --primary-foreground: oklch(0.985 0.01 90);

  --secondary: oklch(0.94 0.02 92);
  --secondary-foreground: oklch(0.235 0.028 55);

  --muted: oklch(0.955 0.012 88);
  --muted-foreground: oklch(0.49 0.03 58);

  /* sage */
  --accent: oklch(0.92 0.03 145);
  --accent-foreground: oklch(0.235 0.028 55);

  --destructive: oklch(0.63 0.2 28);

  --border: oklch(0.83 0.02 88 / 70%);
  --input: oklch(0.83 0.02 88 / 70%);
  --ring: oklch(0.66 0.11 75 / 45%);

  --chart-1: oklch(0.66 0.11 75);
  --chart-2: oklch(0.66 0.08 150);
  --chart-3: oklch(0.62 0.06 40);
  --chart-4: oklch(0.73 0.07 110);
  --chart-5: oklch(0.6 0.09 20);

  --sidebar: oklch(0.968 0.016 88);
  --sidebar-foreground: oklch(0.235 0.028 55);
  --sidebar-primary: oklch(0.66 0.11 75);
  --sidebar-primary-foreground: oklch(0.985 0.01 90);
  --sidebar-accent: oklch(0.94 0.02 92);
  --sidebar-accent-foreground: oklch(0.235 0.028 55);
  --sidebar-border: oklch(0.83 0.02 88 / 70%);
  --sidebar-ring: oklch(0.66 0.11 75 / 45%);
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }

  html {
    color-scheme: light;
  }

  body {
    @apply bg-background text-foreground antialiased;
    font-family: var(--font-body);
  }

  h1,
  h2,
  h3,
  .font-display {
    font-family: var(--font-display);
    letter-spacing: -0.01em;
  }
}

@layer utilities {
  .readable {
    line-height: 1.9;
    letter-spacing: 0.01em;
  }

  /* legacy class name kept to avoid large refactors */
  .gold-border {
    border: 1px solid var(--border);
    box-shadow:
      0 0 0 1px oklch(0.83 0.02 88 / 22%),
      0 18px 50px -42px oklch(0.36 0.03 70 / 25%);
  }

  .gold-glow {
    box-shadow:
      0 0 0 1px oklch(0.66 0.11 75 / 22%),
      0 0 44px oklch(0.66 0.11 75 / 16%),
      0 16px 42px -30px oklch(0.36 0.03 70 / 25%);
  }

  .paper-grain {
    position: relative;
  }

  /* rice paper texture */
  .paper-grain::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.22;
    mix-blend-mode: multiply;
    background-image:
      radial-gradient(circle at 18% 12%, oklch(0.92 0.03 145 / 30%), transparent 55%),
      radial-gradient(circle at 80% 50%, oklch(0.66 0.11 75 / 20%), transparent 52%),
      repeating-linear-gradient(0deg, oklch(0.99 0.004 90 / 22%) 0 1px, transparent 1px 4px),
      repeating-linear-gradient(90deg, oklch(0.99 0.004 90 / 20%) 0 1px, transparent 1px 5px);
  }

  .vignette {
    position: relative;
  }

  .vignette::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at center,
      transparent 0 62%,
      oklch(0.85 0.02 80 / 55%) 100%
    );
    opacity: 0.85;
  }
}
</file>

